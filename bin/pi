#!/usr/bin/env zsh
# Zsh, because macOS bash is old and doesn't support arrays

# Run Pi agent in a Docker container as a sandbox
# Mount ".git" directory in read-only mode to prevent accidental destructive changes to the repository
# Mount git ignored files and directories to prevent accidental modifications

# Pi containerization docs: https://pi.dev/docs/latest/containerization

local tty
if [ -t 0 ]; then
  # Can't pass --tty is STDIN is present
  tty="--tty"
fi

local git_volume
local git_ignores_vulumes
if [ -d '.git' ]; then
  # Read only, so that LLM can't `git push -f` or rebase accidentally
  git_volume=("-v" "$PWD/.git:/workspace/.git:ro")

  # Mount empty anonymous volumes for each git ignore, so that LLM can't modify or delete these untracked files or
  # directories
  local git_ignores=$(git status --ignored --short | grep '^!! ' | grep -v '\.DS_Store$' | cut -d' ' -f2)

  while IFS= read -r git_ignore; do
    if [ -f "$git_ignore" ]; then
      # If it's a file, mount an empty file on top of it
      git_ignores_volumes+=("-v" "/dev/null:/workspace/${git_ignore}:ro")
    else
      # If it's a directory, mount an empty anonymous volume directory on top of it
      git_ignores_volumes+=("-v" "/workspace/$git_ignore")
    fi
  done <<< "$git_ignores"
fi

docker run --rm --interactive \
  ${tty} \
  -e PI_SKIP_VERSION_CHECK=true \
  -e PI_OFFLINE=true \
  -e PI_TELEMETRY=false \
  -v "$PWD:/workspace" \
  -v "$HOME/.pi/agent:/home/pi/.pi/agent" \
  -v "$HOME/.gitignore:/home/pi/.gitignore_global:ro" \
  "$git_volume[@]" \
  "$git_ignores_volumes[@]" \
  --add-host=host.docker.internal:host-gateway \
  pi-agent "$@"
